@{
    ViewData["Title"] = "Giới thiệu";
}

<section class="page-hero compact-hero">
    <div class="container reveal-on-scroll">
        <p class="eyebrow">Giới thiệu</p>
        <h1>Website demo đánh giá nguy cơ bệnh tim bằng ANN</h1>
        <p>
            HeartCare AI được xây dựng như một sản phẩm demo phục vụ báo cáo đề tài, kết hợp giao diện
            dashboard y tế, luồng nhập liệu bệnh nhân, phân tích nguy cơ và thống kê lịch sử.
        </p>
    </div>
</section>

<section class="section-pad">
    <div class="container">
        <div class="row g-4 align-items-start">
            <div class="col-lg-6">
                <div class="content-panel reveal-on-scroll">
                    <h2>Mục tiêu hệ thống</h2>
                    <p>
                        Hệ thống hỗ trợ sàng lọc nguy cơ tim mạch dựa trên các chỉ số thường gặp:
                        tuổi, giới tính, huyết áp tâm thu, cholesterol, đường huyết lúc đói, ECG,
                        tiền sử hút thuốc và một số biến nâng cao.
                    </p>
                    <p>
                        Phiên bản hiện tại dùng thuật toán mô phỏng có thể thay thế bằng API gọi mô hình ANN thật.
                    </p>
                </div>
            </div>
            <div class="col-lg-6">
                <div class="content-panel reveal-on-scroll">
                    <h2>Phù hợp báo cáo 4 chương</h2>
                    <ul class="clean-list">
                        <li>Tổng quan đề tài và bệnh tim mạch.</li>
                        <li>Phân tích, thiết kế hệ thống và cơ sở dữ liệu.</li>
                        <li>Xây dựng, huấn luyện và đánh giá mô hình ANN.</li>
                        <li>Xây dựng website, demo chức năng và kết quả.</li>
                    </ul>
                </div>
            </div>
        </div>
    </div>
</section>
